{
  "hosting": [
    {
      "target": "app-principal",
      "public": "dist-principal",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [ { "source": "**", "destination": "/index.html" } ]
    },
    {
      "target": "app-admin",
      "public": "dist-admin",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [ { "source": "**", "destination": "/index.html" } ]
    }
  ]
}